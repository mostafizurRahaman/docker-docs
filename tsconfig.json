{
   "compilerOptions": {
      "rootDir": "./src",
      "outDir": "./dist",
      "module": "CommonJS",
      "moduleResolution": "node",
      "target": "ESNext",
      "lib": ["ESNext"],
      "types": ["node"],
      "sourceMap": true,
      "declaration": true,
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "ignoreDeprecations": "6.0"
   }
}
